{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pozycje_wzorcowe.schema.json",
  "title": "Pozycje wzorcowe",
  "description": "Baza wzorcowych opisów pozycji kosztorysowych (dla naprawy OCR)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["opis"],
    "properties": {
      "knr": {
        "type": "string",
        "description": "Numer podstawy (KNR, KNNR, KSNR, etc.)"
      },
      "opis": {
        "type": "string",
        "description": "Wzorcowy opis pozycji",
        "minLength": 5,
        "maxLength": 500
      },
      "jednostka": {
        "type": "string",
        "description": "Jednostka miary",
        "maxLength": 20
      }
    },
    "additionalProperties": true
  },
  "minItems": 1
}
